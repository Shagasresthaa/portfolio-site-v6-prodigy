---
import Layout from '../layouts/Layout.astro';
import NavbarComponent from '../components/NavbarComponent.vue';
import PlaceholderPage from '../components/PlaceholderPage.vue';
---

<Layout title="Admin Contact">
	<NavbarComponent client:load currentPath={Astro.url.pathname} pageTitle="Contact" />
	<PlaceholderPage
		client:load
		title="Contact"
		description="Contact form submissions will show up here once the API is ready."
	/>
</Layout>
