---
import '../styles/main.css';
import { getApiBaseUrl } from '../utils/apiBaseUrl';

interface Props {
	title?: string;
}

const { title = 'Portfolio Admin' } = Astro.props;

// Meta-tag CSP (static build, no server for a real header) - frame-ancestors is a no-op here.
// __INLINE_SCRIPT_HASHES__ is a placeholder scripts/fix-csp-hashes.mjs replaces post-build with
// real per-page hashes for Astro's inline hydration scripts; never hand-edit a hash in here.
// style-src keeps 'unsafe-inline' (not Astro's security.csp auto-hash) for NavbarComponent's :style binding.
// Prod-only: dev's inline scripts differ, so the meta tag would just block dev, not protect anything.
const csp = [
	"default-src 'self'",
	"script-src 'self' __INLINE_SCRIPT_HASHES__",
	"style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
	"font-src 'self' https://fonts.gstatic.com",
	// cdn.sresthaa.com is R2's custom public domain; blob: is for pre-upload local previews.
	"img-src 'self' data: blob: https://img.youtube.com https://cdn.sresthaa.com",
	`connect-src 'self' ${getApiBaseUrl()}`,
	"object-src 'none'",
	"base-uri 'self'",
	"form-action 'self'",
].join('; ');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		{!import.meta.env.DEV && <meta http-equiv="Content-Security-Policy" content={csp} />}
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline src="/theme-init.js"></script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		height: 100%;
	}
</style>
